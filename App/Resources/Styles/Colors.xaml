<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Theme: xanh lá đậm + trắng (light, sạch — tham chiếu map discovery) -->
    <!-- Note: For Android see Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#2E7D32</Color>
    <Color x:Key="PrimaryDark">#1B5E20</Color>
    <Color x:Key="PrimaryLight">#66BB6A</Color>
    <Color x:Key="PrimaryDarkText">#1A1C1A</Color>
    <Color x:Key="Secondary">#E8F5E9</Color>
    <Color x:Key="SecondaryDarkText">#1B5E20</Color>
    <Color x:Key="Tertiary">#43A047</Color>
    <Color x:Key="TabHighlight">#E8F5E9</Color>

    <Color x:Key="PageBackground">#F5FAF6</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="BorderSubtle">#D5E5D8</Color>
    <Color x:Key="TextPrimary">#141814</Color>
    <Color x:Key="TextSecondary">#5C6B60</Color>
    <Color x:Key="TextMuted">#8A9A8E</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#2E7D32</Color>
    <Color x:Key="MidnightBlue">#1B5E20</Color>
    <Color x:Key="OffBlack">#1a1f1b</Color>

    <Color x:Key="Gray100">#EDF2EE</Color>
    <Color x:Key="Gray200">#D8E0DA</Color>
    <Color x:Key="Gray300">#B8C4BC</Color>
    <Color x:Key="Gray400">#9AA89E</Color>
    <Color x:Key="Gray500">#6B7A6F</Color>
    <Color x:Key="Gray600">#4A564E</Color>
    <Color x:Key="Gray900">#2A322C</Color>
    <Color x:Key="Gray950">#1A211C</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>