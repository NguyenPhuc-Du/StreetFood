<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="App.Views.HomePage"
    NavigationPage.HasNavigationBar="False">

    <AbsoluteLayout>

        <!-- MAP -->
        <maps:Map
            x:Name="MixiMap"
            MapType="Street"
            IsShowingUser="True"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>


        <!-- SEARCH BAR -->
        <Border
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 30"
            Padding="15"
            Margin="20,50,20,0"
            HeightRequest="55"
            AbsoluteLayout.LayoutBounds="0.5,0,0.9,55"
            AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">

            <Grid ColumnDefinitions="30,*,30">

                <Image
                    Source="ic_search.svg"
                    HeightRequest="20"
                    VerticalOptions="Center"/>

                <Entry
                    Grid.Column="1"
                    Placeholder="Search places"
                    BackgroundColor="Transparent"
                    TextChanged="OnSearchChanged"/>

                <Image
                    Grid.Column="2"
                    Source="ic_filter.svg"
                    HeightRequest="20"
                    HorizontalOptions="End"/>

            </Grid>

        </Border>


        <!-- CATEGORY -->
        <ScrollView
            Orientation="Horizontal"
            Margin="20,120,0,0"
            AbsoluteLayout.LayoutBounds="0,0,1,50"
            AbsoluteLayout.LayoutFlags="WidthProportional">

            <HorizontalStackLayout Spacing="10">

                <Button
                    Text="All"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="25"
                    Padding="20,8"/>

                <Button
                    Text="Shops"
                    BackgroundColor="White"
                    TextColor="Black"
                    CornerRadius="25"
                    Padding="20,8"/>

                <Button
                    Text="POI"
                    BackgroundColor="White"
                    TextColor="Black"
                    CornerRadius="25"
                    Padding="20,8"/>

                <Button
                    Text="Food"
                    BackgroundColor="White"
                    TextColor="Black"
                    CornerRadius="25"
                    Padding="20,8"/>

            </HorizontalStackLayout>

        </ScrollView>


        <!-- GPS BUTTON -->
        <Border
            BackgroundColor="White"
            StrokeThickness="0"
            WidthRequest="50"
            HeightRequest="50"
            StrokeShape="RoundRectangle 25"
            AbsoluteLayout.LayoutBounds="0.95,0.35,50,50"
            AbsoluteLayout.LayoutFlags="PositionProportional">

            <Image
                Source="ic_map.svg"
                Margin="10"/>

        </Border>


        <!-- BOTTOM INFO CARD -->
        <Border
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 25"
            Padding="15"
            Margin="20"
            AbsoluteLayout.LayoutBounds="0.5,1,0.9,160"
            AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">

            <Grid ColumnDefinitions="*,100">

                <VerticalStackLayout Spacing="6">

                    <Label
                        x:Name="PlaceName"
                        Text="Nearby place"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="Black"/>

                    <HorizontalStackLayout Spacing="5">

                        <Image
                            Source="ic_star.svg"
                            HeightRequest="14"/>

                        <Label
                            x:Name="PlaceRating"
                            Text="4.8 (120 reviews)"
                            FontSize="13"
                            TextColor="Gray"/>

                    </HorizontalStackLayout>

                    <Label
                        x:Name="PlaceStatus"
                        Text="Open • Closes 8 PM"
                        FontSize="13"
                        TextColor="#2E7D32"/>


                    <HorizontalStackLayout
                        Spacing="15"
                        Margin="0,5,0,0">

                        <Button
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="#2E7D32"
                            Clicked="OnPlayClicked"
                            ImageSource="ic_play.svg"/>

                        <Button
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="#E0E0E0"
                            Clicked="OnPauseClicked"
                            ImageSource="ic_pause.svg"/>

                        <Button
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="#2196F3"
                            Clicked="OnNavigateClicked"
                            ImageSource="ic_navigation.svg"/>

                    </HorizontalStackLayout>

                </VerticalStackLayout>


                <Image
                    x:Name="PlaceImage"
                    Grid.Column="1"
                    HeightRequest="90"
                    WidthRequest="90"
                    Aspect="AspectFill"
                    HorizontalOptions="End"
                    VerticalOptions="Center"/>

            </Grid>

        </Border>

    </AbsoluteLayout>

</ContentPage>