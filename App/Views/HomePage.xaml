<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="App.Views.HomePage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">
        <maps:Map x:Name="MixiMap" IsShowingUser="True" Grid.RowSpan="2" MapClicked="OnMapClicked"/>

        <toolkit:MediaElement x:Name="AudioPlayer" 
                              ShouldAutoPlay="False" 
                              Grid.RowSpan="2"
                              IsVisible="False" />

        <Grid Grid.Row="0" Padding="16,48,16,10" ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border StrokeShape="RoundRectangle 22"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Padding="14,8">
                <Border.Stroke>
                    <SolidColorBrush Color="{StaticResource BorderSubtle}"/>
                </Border.Stroke>
                <Border.Shadow>
                    <Shadow Brush="#101828" Offset="0,4" Radius="16" Opacity="0.15"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                    <Image Source="ic_search.svg" HeightRequest="18" WidthRequest="18" Margin="2,0,10,0"/>
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Placeholder="Tìm quán ăn hoặc POI"
                           TextChanged="OnSearchTextChanged"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource TextMuted}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,240"
                StrokeShape="RoundRectangle 30"
                BackgroundColor="{StaticResource SurfaceCard}"
                Padding="14,10"
                ZIndex="10">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.2"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGetLocationClicked" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="8">
                <Label Text="◎" FontSize="14" TextColor="{StaticResource Primary}" />
                <Label Text="Vị trí của tôi" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="13"/>
            </HorizontalStackLayout>
        </Border>

        <Border x:Name="InfoCard"
                IsVisible="False"
                Grid.RowSpan="2"
                VerticalOptions="End"
                Margin="14,0,14,24"
                Stroke="{StaticResource BorderSubtle}"
                StrokeShape="RoundRectangle 30"
                BackgroundColor="{StaticResource SurfaceCard}"
                ZIndex="100">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,6" Radius="15" Opacity="0.25"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto" RowSpacing="0">
                <!-- Vùng kéo: Pointer hoạt động ổn định trên Android hơn Pan/Swipe một mình -->
                <Grid Grid.Row="0"
                      RowDefinitions="Auto,Auto"
                      Padding="12,12,12,8"
                      RowSpacing="10"
                      BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <PointerGestureRecognizer PointerPressed="OnInfoCardPointerPressed"
                                                  PointerReleased="OnInfoCardPointerReleased"/>
                        <PanGestureRecognizer PanUpdated="OnInfoCardPanUpdated"/>
                        <SwipeGestureRecognizer Direction="Down" Swiped="OnInfoCardSwipedDown"/>
                    </Grid.GestureRecognizers>

                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                        <VerticalStackLayout Spacing="6" VerticalOptions="Center">
                            <BoxView HeightRequest="5"
                                     WidthRequest="44"
                                     CornerRadius="3"
                                     HorizontalOptions="Start"
                                     Color="{StaticResource Gray100}"/>
                            <Label Text="Kéo xuống để đóng thẻ và tắt âm thanh"
                                   FontSize="11"
                                   TextColor="{StaticResource TextMuted}"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="Đóng"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center"
                               Padding="8,4">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInfoCardCloseTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="96,*"
                          ColumnSpacing="10">
                        <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" HeightRequest="104" WidthRequest="96" VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInfoCardTapped" />
                            </Border.GestureRecognizers>
                            <Image x:Name="PlaceImage" Aspect="AspectFill" Source="logo.png"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInfoCardTapped" />
                            </VerticalStackLayout.GestureRecognizers>
                            <Label x:Name="PlaceName" FontAttributes="Bold" FontSize="18" MaxLines="2" LineBreakMode="TailTruncation" TextColor="{StaticResource TextPrimary}"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label x:Name="PlaceStatus" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                                <Label x:Name="PlaceHours" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                            </HorizontalStackLayout>
                            <Label x:Name="PlaceAddress" FontSize="12" TextColor="{StaticResource TextSecondary}" MaxLines="2" LineBreakMode="WordWrap"/>
                            <Label x:Name="PlacePhone" FontSize="12" TextColor="{StaticResource TextMuted}" MaxLines="1" LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Padding="12,0,12,12">
                    <Button Grid.Column="0"
                            Text="Phát"
                            Clicked="OnPlayClicked"
                            HeightRequest="44"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource SecondaryDarkText}"
                            FontAttributes="Bold"
                            CornerRadius="14"/>
                    <Button Grid.Column="1"
                            Text="Tạm dừng"
                            Clicked="OnPauseClicked"
                            HeightRequest="44"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="#B71C1C"
                            FontAttributes="Bold"
                            CornerRadius="14"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>