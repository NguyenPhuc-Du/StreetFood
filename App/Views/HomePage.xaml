<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="App.Views.HomePage"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- MAP -->
        <maps:Map
            x:Name="MixiMap"
            MapType="Street"
            IsShowingUser="True"/>

        <!-- SEARCH BAR -->
        <Grid
            Margin="20,60,20,0"
            HeightRequest="55"
            VerticalOptions="Start">

            <Frame
                BackgroundColor="White"
                CornerRadius="30"
                HasShadow="True">

                <Grid ColumnDefinitions="40,*,40">

                    <Image
                        Source="search.png"
                        HeightRequest="20"
                        VerticalOptions="Center"/>

                    <Entry
                        x:Name="SearchEntry"
                        Grid.Column="1"
                        Placeholder="Search shops or points of interest"
                        FontSize="16"
                        TextChanged="OnSearchChanged"/>

                    <Image
                        Grid.Column="2"
                        Source="filter.png"
                        HeightRequest="20"
                        VerticalOptions="Center"/>

                </Grid>

            </Frame>

        </Grid>

        <!-- FILTER CHIPS -->
        <HorizontalStackLayout
            Margin="20,130,20,0"
            Spacing="10"
            VerticalOptions="Start">

            <Button
                Text="All"
                Clicked="OnAllFilter"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="20"/>

            <Button
                Text="Shops"
                Clicked="OnShopFilter"
                BackgroundColor="#F1F1F1"
                TextColor="Black"
                CornerRadius="20"/>

            <Button
                Text="POI"
                Clicked="OnPoiFilter"
                BackgroundColor="#F1F1F1"
                TextColor="Black"
                CornerRadius="20"/>

            <Button
                Text="Food"
                Clicked="OnFoodFilter"
                BackgroundColor="#F1F1F1"
                TextColor="Black"
                CornerRadius="20"/>

        </HorizontalStackLayout>

        <!-- FLOATING BUTTONS -->
        <VerticalStackLayout
            Spacing="15"
            Margin="0,0,20,160"
            VerticalOptions="End"
            HorizontalOptions="End">

            <!-- LAYER -->
            <Frame
                BackgroundColor="White"
                HeightRequest="50"
                WidthRequest="50"
                CornerRadius="25"
                HasShadow="True">

                <Image
                    Source="layers.png"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
            </Frame>

            <!-- LOCATION -->
            <Frame
                BackgroundColor="White"
                HeightRequest="50"
                WidthRequest="50"
                CornerRadius="25"
                HasShadow="True">

                <Image
                    Source="location.png"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocationClicked"/>
                    </Image.GestureRecognizers>

                </Image>

            </Frame>

        </VerticalStackLayout>

        <!-- BOTTOM PLACE CARD -->
        <Frame
            Margin="20,0,20,90"
            VerticalOptions="End"
            CornerRadius="20"
            BackgroundColor="White"
            HasShadow="True">

            <Grid ColumnDefinitions="80,*,60">

                <Image
                    Source="shop.png"
                    HeightRequest="60"
                    WidthRequest="60"
                    Aspect="AspectFill"/>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="3">

                    <Label
                        x:Name="PlaceName"
                        Text="Place name"
                        FontAttributes="Bold"
                        FontSize="16"/>

                    <Label
                        Text="⭐ 4.8 (120 reviews)"
                        FontSize="13"
                        TextColor="Gray"/>

                    <Label
                        Text="Open • Closes 8 PM"
                        FontSize="13"
                        TextColor="#2E7D32"/>

                </VerticalStackLayout>

                <Frame
                    Grid.Column="2"
                    BackgroundColor="#2E7D32"
                    CornerRadius="25"
                    HeightRequest="45"
                    WidthRequest="45"
                    VerticalOptions="Center">

                    <Image
                        Source="direction.png"
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavigateClicked"/>
                        </Image.GestureRecognizers>

                    </Image>

                </Frame>

            </Grid>

        </Frame>

    </Grid>

</ContentPage>