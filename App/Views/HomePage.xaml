<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="App.Views.HomePage"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <maps:Map x:Name="MixiMap" IsShowingUser="True" />

        <VerticalStackLayout VerticalOptions="Start" Margin="15,45,15,0">
            <Border BackgroundColor="White" 
                    Padding="10,0" 
                    StrokeShape="RoundRectangle 25" 
                    StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                </Border.Shadow>
                <Grid ColumnDefinitions="40,*">
                    <Image Source="ic_search.svg" 
                           VerticalOptions="Center" 
                           HorizontalOptions="Center" 
                           HeightRequest="20" 
                           WidthRequest="20" />

                    <Entry Grid.Column="1" 
                           Placeholder="Tìm kiếm địa điểm..." 
                           TextChanged="OnSearchChanged" 
                           BackgroundColor="Transparent" 
                           FontSize="14" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Button Text="My Location" 
                FontAttributes="Bold"
                TextColor="#2f7f34"
                BackgroundColor="White"
                CornerRadius="20"
                HeightRequest="40"
                WidthRequest="130"
                VerticalOptions="End" 
                HorizontalOptions="End" 
                Margin="0,0,20,80" 
                Clicked="OnGetLocationClicked">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.2" />
            </Button.Shadow>
        </Button>

        <Border x:Name="InfoCard" 
                IsVisible="False" 
                VerticalOptions="End" 
                Margin="15,0,15,20" 
                Padding="12" 
                StrokeShape="RoundRectangle 20" 
                BackgroundColor="White"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1" />
            </Border.Shadow>

            <Grid ColumnDefinitions="80, *, Auto" ColumnSpacing="12">
                <Image x:Name="PlaceImage" Aspect="AspectFill" HeightRequest="80" WidthRequest="80" Source="logo.png" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label x:Name="PlaceName" FontAttributes="Bold" FontSize="15" TextColor="Black" Text="Tên địa điểm"/>
                    <HorizontalStackLayout Spacing="15" Margin="0,10,0,0">
                        <ImageButton Source="ic_play.svg" Clicked="OnPlayClicked" HeightRequest="30" WidthRequest="30"/>
                        <ImageButton Source="ic_pause.svg" Clicked="OnPauseClicked" HeightRequest="30" WidthRequest="30"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="Go" Clicked="OnNavigateClicked" BackgroundColor="#2f7f34" CornerRadius="20" TextColor="White"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>