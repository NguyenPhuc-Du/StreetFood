<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App.Views.SplashPage"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1B5E20" Offset="0.0"/>
                <GradientStop Color="#43A047" Offset="0.55"/>
                <GradientStop Color="#E8F5E9" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="20">

            <!-- Logo -->
            <Image
                Source="logo.png"
                HeightRequest="120"/>

            <!-- Title -->
            <Label
                Text="Smart Market Tour"
                FontSize="36"
                TextColor="White"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>

        <!-- Bottom loading -->
        <VerticalStackLayout
            VerticalOptions="End"
            Padding="30"
            Spacing="10">

            <Grid ColumnDefinitions="*,Auto">

                <Label
                    x:Name="LoadingLabel"
                    TextColor="White"
                    FontAttributes="Bold"/>

                <Label
                    x:Name="PercentLabel"
                    Grid.Column="1"
                    Text="0%"
                    TextColor="White"/>
            </Grid>

            <ProgressBar
                x:Name="LoadingBar"
                Progress="0"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>