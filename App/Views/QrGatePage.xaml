<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="App.Views.QrGatePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PrimaryDark}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0,0,0,24">
        <VerticalStackLayout Grid.Row="0" Padding="24,52,24,16" Spacing="8">
            <Label x:Name="QrTitleLabel"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Margin="16,0">
            <Border x:Name="CameraFrame"
                    StrokeShape="RoundRectangle 20"
                    Stroke="{StaticResource PrimaryLight}"
                    StrokeThickness="2"
                    BackgroundColor="Black"
                    Padding="0"
                    IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.35"/>
                </Border.Shadow>
                <zxing:CameraBarcodeReaderView x:Name="CameraView"
                                               BarcodesDetected="OnBarcodesDetected"/>
            </Border>

            <Border x:Name="ManualPanel"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Padding="20"
                    IsVisible="False">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="QrManualDescLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="WordWrap"/>
                    <Entry x:Name="ManualCodeEntry"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource TextMuted}"
                           BackgroundColor="{StaticResource Gray100}"/>
                    <Button x:Name="QrConfirmButton"
                            Clicked="OnManualConfirmClicked"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="48"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <VerticalStackLayout Grid.Row="2" Padding="24,8" Spacing="10">
            <ActivityIndicator x:Name="BusyIndicator" IsVisible="False" Color="White"/>
            <Label x:Name="ErrorLabel"
                   TextColor="#FFCDD2"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   IsVisible="False"
                   LineBreakMode="WordWrap"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
