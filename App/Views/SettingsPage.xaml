<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App.Views.SettingsPage"
             NavigationPage.HasNavigationBar="False">

    <ScrollView BackgroundColor="{StaticResource PageBackground}">
        <VerticalStackLayout Padding="18,40,18,24" Spacing="14">
            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="0,0,0,8">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Cài đặt" FontSize="34" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                    <Label Text="Tùy chỉnh trải nghiệm phù hợp với bạn" FontSize="13" TextColor="{StaticResource TextMuted}"/>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 24" Padding="16" BackgroundColor="{StaticResource SurfaceCard}" Stroke="{StaticResource BorderSubtle}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Tự động phát audio khi ở gần"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap"/>
                        <Label Text="Tự phát audio khi bạn đi vào phạm vi của quán trên bản đồ."
                               FontSize="13"
                               TextColor="{StaticResource TextMuted}"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Switch x:Name="AutoAudioSwitch"
                            IsToggled="True"
                            OnColor="{StaticResource Primary}"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Toggled="OnAutoAudioSwitchToggled"/>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 24" Padding="16" BackgroundColor="{StaticResource SurfaceCard}" Stroke="{StaticResource BorderSubtle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ngôn ngữ ứng dụng" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                    <Label Text="Chọn ngôn ngữ bạn muốn dùng để nhận nội dung phù hợp."
                           FontSize="13"
                           TextColor="{StaticResource TextMuted}"/>

                    <Border StrokeShape="RoundRectangle 16" Padding="12" BackgroundColor="{StaticResource Secondary}" Stroke="{StaticResource BorderSubtle}">
                        <VerticalStackLayout Spacing="10">
                            <RadioButton x:Name="LangViRadio" Content="Tiếng Việt" Value="vi" CheckedChanged="OnLanguageRadioCheckedChanged" TextColor="{StaticResource TextPrimary}"/>
                            <RadioButton x:Name="LangEnRadio" Content="English" Value="en" CheckedChanged="OnLanguageRadioCheckedChanged" TextColor="{StaticResource TextPrimary}"/>
                            <RadioButton x:Name="LangJaRadio" Content="日本語" Value="ja" CheckedChanged="OnLanguageRadioCheckedChanged" TextColor="{StaticResource TextPrimary}"/>
                            <RadioButton x:Name="LangKoRadio" Content="한국어" Value="ko" CheckedChanged="OnLanguageRadioCheckedChanged" TextColor="{StaticResource TextPrimary}"/>
                            <RadioButton x:Name="LangZhRadio" Content="中文" Value="zh" CheckedChanged="OnLanguageRadioCheckedChanged" TextColor="{StaticResource TextPrimary}"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 24" Padding="16" BackgroundColor="{StaticResource SurfaceCard}" Stroke="{StaticResource BorderSubtle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Gợi ý trải nghiệm" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource Primary}"/>
                    <Label Text="Vào trang gợi ý để xem quán gần nhất và mở nhanh trang chi tiết."
                           FontSize="12"
                           TextColor="{StaticResource TextMuted}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

